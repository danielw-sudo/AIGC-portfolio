{
  "name": "aigc-portfolio",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "deploy": "npm run build && wrangler deploy",
    "db:schema": "wrangler d1 execute your-db-name --local --file=schema.sql",
    "db:schema:remote": "wrangler d1 execute your-db-name --remote --file=schema.sql",
    "db:seed": "wrangler d1 execute your-db-name --local --file=migrations/0002_seed_models.sql",
    "db:seed:remote": "wrangler d1 execute your-db-name --remote --file=migrations/0002_seed_models.sql"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.1.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.0",
    "astro": "^6.0.6",
    "clsx": "^2.1.0",
    "imagesloaded": "^5.0.0",
    "marked": "^17.0.3",
    "masonry-layout": "^4.2.2",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "lucide-static": "^0.577.0",
    "typescript": "^5.7.0",
    "wrangler": "^4.0.0"
  }
}
