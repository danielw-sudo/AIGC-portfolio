---
import MainLayout from '@/layouts/MainLayout.astro';
import { TaxonomyService, SettingsService } from '@/lib/data';

const { env } = Astro.locals.runtime;
const taxonomy = new TaxonomyService(env.DB);
const settings = new SettingsService(env.DB);
const [models, metaDesc] = await Promise.all([
  taxonomy.getModelsWithCount(),
  settings.getMetaDesc('models', 'The AI friends helping me create.'),
]);
---

<MainLayout title="Models" description={metaDesc}>
  <section class="max-w-4xl mx-auto px-4 pt-8 sm:pt-12 pb-16">
    <h1 class="text-2xl sm:text-3xl font-extrabold tracking-tight mb-8">Models</h1>
    <div class="grid gap-3">
      {models.map((m) => (
        <a
          href={`/models/${m.slug}`}
          class="flex items-center justify-between bg-surface-raised hover:bg-surface-overlay
                 border border-border rounded-lg px-4 py-3 transition-colors group"
        >
          <div>
            <span class="font-medium text-text-primary">{m.title}</span>
            {m.provider && <span class="text-text-muted text-sm ml-2">by {m.provider}</span>}
          </div>
          <div class="flex items-center gap-2">
            <span class="text-sm text-text-muted">{m.entry_count}</span>
            <span class="text-text-muted group-hover:text-text-secondary transition-colors">→</span>
          </div>
        </a>
      ))}
    </div>
  </section>
</MainLayout>
