---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { MigrationService } from '@/lib/data';

import type { MigrationRow } from '@/lib/data/migrations';

const { env } = Astro.locals.runtime;
const svc = new MigrationService(env.DB);
let history: MigrationRow[] = [];
let loadError = '';
try {
  history = await svc.list();
} catch (e) {
  loadError = (e as Error).message;
}
---

<AdminLayout title="Migrations">
  <div class="max-w-3xl">
    <h1 class="text-2xl font-bold mb-2">Migrations</h1>
    <p class="text-sm text-gray-500 mb-6">
      Execute D1 schema scripts generated by your AI assistant.
      Execute D1 schema scripts. Paste SQL from <code class="text-purple-400">schema.sql</code> for initial setup.
    </p>

    {loadError && (
      <div class="mb-4 px-4 py-2 rounded-lg text-sm bg-red-900/50 text-red-300">
        Failed to load history: {loadError}
      </div>
    )}
    <div id="message" class="hidden mb-4 px-4 py-2 rounded-lg text-sm"></div>

    <!-- Run Migration -->
    <section class="mb-10">
      <h2 class="text-lg font-semibold mb-3">Run Migration</h2>

      <label for="migration-name" class="block text-sm text-gray-300 mb-1">Name</label>
      <input
        type="text"
        id="migration-name"
        placeholder="e.g. add-blog-collection"
        maxlength="200"
        class="w-full bg-gray-900 border border-gray-700 rounded-lg px-3 py-2 text-white text-sm mb-4
               focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500"
      />

      <label for="migration-sql" class="block text-sm text-gray-300 mb-1">SQL</label>
      <textarea
        id="migration-sql"
        rows="12"
        placeholder="Paste SQL here..."
        class="w-full bg-gray-900 border border-gray-700 rounded-lg px-3 py-2 text-white font-mono text-sm mb-4
               focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500"
      ></textarea>

      <div class="flex gap-3">
        <button type="button" id="preview-btn"
          class="bg-gray-700 hover:bg-gray-600 text-white font-medium py-2 px-5 rounded-lg transition-colors cursor-pointer">
          Preview
        </button>
        <button type="button" id="execute-btn" disabled
          class="bg-blue-600 hover:bg-blue-500 text-white font-medium py-2 px-5 rounded-lg transition-colors
                 disabled:opacity-40 disabled:cursor-not-allowed cursor-pointer">
          Execute
        </button>
      </div>
    </section>

    <!-- Preview Panel -->
    <section id="preview-panel" class="hidden mb-10">
      <h2 class="text-lg font-semibold mb-2">Preview</h2>
      <pre id="preview-output"
        class="bg-gray-900 border border-gray-700 rounded-lg p-4 text-sm font-mono text-gray-300
               overflow-x-auto max-h-64 overflow-y-auto whitespace-pre-wrap"></pre>
      <p id="preview-count" class="text-xs text-gray-500 mt-2"></p>
    </section>

    <!-- Migration History -->
    <section>
      <h2 class="text-lg font-semibold mb-3">History</h2>
      {history.length === 0 ? (
        <p class="text-sm text-gray-500">No migrations recorded yet.</p>
      ) : (
        <div class="space-y-2" id="history-list">
          {history.map((m) => (
            <div class="flex items-center justify-between bg-gray-900 border border-gray-700 rounded-lg px-4 py-3">
              <div>
                <p class="text-sm font-medium text-white">{m.name}</p>
                <p class="text-xs text-gray-500 font-mono">{m.sql_hash.slice(0, 12)}...</p>
              </div>
              <p class="text-xs text-gray-500">{m.executed_at}</p>
            </div>
          ))}
        </div>
      )}
    </section>
  </div>

  <script>
    const nameEl = document.getElementById('migration-name') as HTMLInputElement;
    const sqlEl = document.getElementById('migration-sql') as HTMLTextAreaElement;
    const previewBtn = document.getElementById('preview-btn') as HTMLButtonElement;
    const executeBtn = document.getElementById('execute-btn') as HTMLButtonElement;
    const previewPanel = document.getElementById('preview-panel')!;
    const previewOutput = document.getElementById('preview-output')!;
    const previewCount = document.getElementById('preview-count')!;
    const msgEl = document.getElementById('message')!;
    const historyList = document.getElementById('history-list');

    function showMessage(text: string, isError: boolean) {
      msgEl.textContent = text;
      msgEl.className = `mb-4 px-4 py-2 rounded-lg text-sm ${
        isError ? 'bg-red-900/50 text-red-300' : 'bg-green-900/50 text-green-300'
      }`;
    }

    function parseStatements(sql: string): string[] {
      return sql
        .split(';')
        .map((s) => s.trim())
        .filter((s) => s.length > 0);
    }

    // Preview
    previewBtn.addEventListener('click', () => {
      const sql = sqlEl.value.trim();
      if (!sql) { showMessage('SQL is empty', true); return; }

      const stmts = parseStatements(sql);
      previewOutput.textContent = stmts.map((s, i) => `-- [${i + 1}]\n${s};`).join('\n\n');
      previewCount.textContent = `${stmts.length} statement${stmts.length !== 1 ? 's' : ''} will be executed`;
      previewPanel.classList.remove('hidden');
      executeBtn.disabled = false;
    });

    // Execute
    executeBtn.addEventListener('click', async () => {
      const name = nameEl.value.trim();
      const sql = sqlEl.value.trim();

      if (!name) { showMessage('Name is required', true); return; }
      if (!sql) { showMessage('SQL is required', true); return; }

      executeBtn.disabled = true;
      executeBtn.textContent = 'Executing...';

      try {
        const res = await fetch('/api/admin/migrations', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, sql }),
        });
        const data = await res.json();

        if (!res.ok) throw new Error(data.error || 'Execution failed');

        showMessage(`Migration "${name}" executed successfully.`, false);

        // Append to history
        if (historyList) {
          const row = document.createElement('div');
          row.className = 'flex items-center justify-between bg-gray-900 border border-gray-700 rounded-lg px-4 py-3';
          row.innerHTML = `<div>
            <p class="text-sm font-medium text-white">${escHtml(data.name)}</p>
            <p class="text-xs text-gray-500 font-mono">${escHtml(data.sql_hash.slice(0, 12))}...</p>
          </div>
          <p class="text-xs text-gray-500">${escHtml(data.executed_at)}</p>`;
          historyList.prepend(row);
        }

        // Clear form
        nameEl.value = '';
        sqlEl.value = '';
        previewPanel.classList.add('hidden');
        executeBtn.disabled = true;
      } catch (err) {
        showMessage((err as Error).message, true);
        executeBtn.disabled = false;
      } finally {
        executeBtn.textContent = 'Execute';
      }
    });

    function escHtml(s: string): string {
      const d = document.createElement('div');
      d.textContent = s;
      return d.innerHTML;
    }
  </script>
</AdminLayout>
