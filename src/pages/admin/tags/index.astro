---
import { env } from "cloudflare:workers";
import AdminLayout from '@/layouts/AdminLayout.astro';
import { TaxonomyService } from '@/lib/data';

const taxonomy = new TaxonomyService(env.DB);
const tags = await taxonomy.getTagsWithCount();
---

<AdminLayout title="Tags">
  <div class="max-w-3xl">
    <h1 class="text-2xl font-bold mb-6">Tags</h1>

    <div id="message" class="hidden mb-4 px-4 py-2 rounded-lg text-sm"></div>

    <!-- Inline create form -->
    <form id="create-form" class="flex gap-2 mb-6">
      <input
        type="text"
        id="new-title"
        placeholder="Tag name"
        required
        class="flex-1 bg-gray-900 border border-gray-700 rounded-lg px-3 py-2 text-white
               focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500"
      />
      <button
        type="submit"
        class="bg-blue-600 hover:bg-blue-500 text-white font-medium px-4 py-2 rounded-lg transition-colors whitespace-nowrap"
      >
        + Add
      </button>
    </form>

    <!-- Tags list -->
    <div id="tags-list" class="space-y-2">
      {tags.map((t) => (
        <div class="flex items-center justify-between bg-gray-900 border border-gray-800 rounded-lg px-4 py-3 group" data-tag-id={t.id}>
          <div>
            <span class="font-medium text-white">#{t.title}</span>
            <span class="text-gray-600 text-xs ml-2">({t.entry_count} entries)</span>
          </div>
          <div class="flex items-center gap-2 sm:opacity-0 sm:group-hover:opacity-100 transition-opacity">
            <a href={`/admin/tags/${t.id}`} class="text-sm text-blue-400 hover:text-blue-300">Edit</a>
            <button class="delete-tag text-sm text-red-400 hover:text-red-300" data-tag-id={t.id} data-count={t.entry_count}>
              Delete
            </button>
          </div>
        </div>
      ))}
      {tags.length === 0 && (
        <p class="text-gray-500 text-center py-8">No tags yet</p>
      )}
    </div>
  </div>

  <script>
    const createForm = document.getElementById('create-form') as HTMLFormElement;
    const tagsList = document.getElementById('tags-list')!;
    const msgEl = document.getElementById('message')!;

    function showMessage(text: string, isError: boolean) {
      msgEl.textContent = text;
      msgEl.className = `mb-4 px-4 py-2 rounded-lg text-sm ${isError ? 'bg-red-900/50 text-red-300' : 'bg-green-900/50 text-green-300'}`;
    }

    createForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const title = (document.getElementById('new-title') as HTMLInputElement).value.trim();
      if (!title) return;

      try {
        const res = await fetch('/api/tags', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ title }),
        });
        if (!res.ok) throw new Error((await res.json()).error || 'Failed');
        window.location.reload();
      } catch (err) {
        showMessage((err as Error).message, true);
      }
    });

    tagsList.addEventListener('click', async (e) => {
      const btn = (e.target as HTMLElement).closest('.delete-tag') as HTMLElement | null;
      if (!btn) return;

      const id = btn.dataset.tagId;
      const count = Number(btn.dataset.count);
      const msg = count > 0
        ? `This tag has ${count} entries. Tag links will be removed. Continue?`
        : 'Delete this tag?';

      if (!confirm(msg)) return;

      try {
        const res = await fetch(`/api/tags/${id}`, { method: 'DELETE' });
        if (!res.ok) throw new Error('Delete failed');
        btn.closest('[data-tag-id]')?.remove();
        showMessage('Deleted ✓', false);
      } catch (err) {
        showMessage((err as Error).message, true);
      }
    });
  </script>
</AdminLayout>
