---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { TaxonomyService } from '@/lib/data';

const { env } = Astro.locals.runtime;
const id = Number(Astro.params.id);
if (!id) return Astro.redirect('/admin/models');

const taxonomy = new TaxonomyService(env.DB);
const model = await taxonomy.getModelById(id);
if (!model) return Astro.redirect('/admin/models');
---

<AdminLayout title={`Edit: ${model.title}`}>
  <div class="max-w-xl">
    <h1 class="text-2xl font-bold mb-6">Edit Model</h1>
    <div id="message" class="hidden mb-4 px-4 py-2 rounded-lg text-sm"></div>

    <form id="edit-form" class="space-y-4">
      <div>
        <label for="title" class="block text-sm text-gray-400 mb-1">Title</label>
        <input type="text" id="title" value={model.title} required
          class="w-full bg-gray-900 border border-gray-700 rounded-lg px-3 py-2 text-white
                 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500" />
      </div>
      <div>
        <label for="provider" class="block text-sm text-gray-400 mb-1">Provider</label>
        <input type="text" id="provider" value={model.provider || ''}
          class="w-full bg-gray-900 border border-gray-700 rounded-lg px-3 py-2 text-white
                 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500" />
      </div>
      <p class="text-xs text-gray-600">Slug: {model.slug} · Created: {model.created_at}</p>
      <div class="flex gap-3 pt-2">
        <button type="submit" id="save-btn"
          class="bg-blue-600 hover:bg-blue-500 text-white font-medium py-2 px-6 rounded-lg transition-colors">
          Save
        </button>
        <a href="/admin/models" class="text-gray-400 hover:text-white py-2 px-4 transition-colors">Back</a>
      </div>
    </form>
  </div>

  <script define:vars={{ modelId: id }}>
    const form = document.getElementById('edit-form');
    const saveBtn = document.getElementById('save-btn');
    const msgEl = document.getElementById('message');

    function showMessage(text, isError) {
      msgEl.textContent = text;
      msgEl.className = `mb-4 px-4 py-2 rounded-lg text-sm ${isError ? 'bg-red-900/50 text-red-300' : 'bg-green-900/50 text-green-300'}`;
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      saveBtn.disabled = true;
      saveBtn.textContent = 'Saving...';
      try {
        const res = await fetch(`/api/models/${modelId}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            title: document.getElementById('title').value.trim(),
            provider: document.getElementById('provider').value.trim(),
          }),
        });
        if (!res.ok) throw new Error((await res.json()).error || 'Update failed');
        showMessage('Saved ✓', false);
      } catch (err) {
        showMessage(err.message, true);
      } finally {
        saveBtn.disabled = false;
        saveBtn.textContent = 'Save';
      }
    });
  </script>
</AdminLayout>
