---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { SettingsService } from '@/lib/data';

const { env } = Astro.locals.runtime;
const settings = new SettingsService(env.DB);

const heroTitle = (await settings.get('site_hero_title')) || '';
const heroSubtitle = (await settings.get('site_hero_subtitle')) || '';
const heroCta1 = JSON.parse((await settings.get('site_hero_cta_1')) || '{"text":"","url":""}');
const heroCta2 = JSON.parse((await settings.get('site_hero_cta_2')) || '{"text":"","url":""}');
const headerLinks = JSON.parse((await settings.get('site_header_links')) || '[]') as { text: string; url: string }[];
const footerLinks = JSON.parse((await settings.get('site_footer_links')) || '[]') as { text: string; url: string }[];

// Meta descriptions (editable, with hardcoded defaults as placeholders)
const metaHome = (await settings.get('meta_desc_home')) || '';
const metaGallery = (await settings.get('meta_desc_gallery')) || '';
const metaTags = (await settings.get('meta_desc_tags')) || '';
const metaModels = (await settings.get('meta_desc_models')) || '';
const metaBlog = (await settings.get('meta_desc_blog')) || '';
const metaBlogTopics = (await settings.get('meta_desc_blog_topics')) || '';
---

<AdminLayout title="Site Config">
  <h1 class="text-2xl font-bold mb-1">Site Config</h1>
  <p class="text-gray-500 text-sm mb-6">Dynamic hero, header, and footer settings. Changes take effect immediately.</p>
  <div id="message" class="hidden mb-4 px-4 py-2 rounded-lg text-sm"></div>

  <div class="space-y-8 pb-12">
    <!-- Hero Section -->
    <section class="bg-gray-900 rounded-lg p-5 border border-gray-700">
      <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Hero</h2>
      <div class="space-y-4">
        <div>
          <label for="hero-title" class="block text-sm text-gray-400 mb-1">Title</label>
          <input type="text" id="hero-title" value={heroTitle} placeholder="Your Site Name"
            class="w-full bg-gray-900 border border-gray-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500" />
          <p class="text-[11px] text-gray-600 mt-1">Supports HTML. Example: My&lt;span class="text-accent"&gt;Gallery&lt;/span&gt;</p>
        </div>
        <div>
          <label for="hero-subtitle" class="block text-sm text-gray-400 mb-1">Subtitle</label>
          <input type="text" id="hero-subtitle" value={heroSubtitle} placeholder="Curated AI-generated art with the prompts that made them."
            class="w-full bg-gray-900 border border-gray-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500" />
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <p class="text-xs text-gray-500 mb-2">Primary CTA</p>
            <input type="text" id="cta1-text" value={heroCta1.text} placeholder="Browse Gallery"
              class="w-full bg-gray-900 border border-gray-700 rounded-lg px-3 py-2 text-white text-sm mb-2 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500" />
            <input type="text" id="cta1-url" value={heroCta1.url} placeholder="/gallery"
              class="w-full bg-gray-900 border border-gray-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500" />
          </div>
          <div>
            <p class="text-xs text-gray-500 mb-2">Secondary CTA</p>
            <input type="text" id="cta2-text" value={heroCta2.text} placeholder="Read the Blog"
              class="w-full bg-gray-900 border border-gray-700 rounded-lg px-3 py-2 text-white text-sm mb-2 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500" />
            <input type="text" id="cta2-url" value={heroCta2.url} placeholder="/blog"
              class="w-full bg-gray-900 border border-gray-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500" />
          </div>
        </div>
      </div>
    </section>

    <!-- Hero Live Preview -->
    <div class="bg-gray-950 rounded-lg p-6 border border-gray-800">
      <p class="text-[10px] text-gray-600 uppercase tracking-wider mb-3">Preview</p>
      <div class="text-center">
        <h3 id="preview-title" class="text-3xl tracking-tight text-white mb-2"></h3>
        <p id="preview-subtitle" class="text-gray-400 text-sm mb-4"></p>
        <div class="flex items-center justify-center gap-2">
          <span id="preview-cta1" class="inline-block px-4 py-1.5 bg-accent text-white text-xs rounded-lg"></span>
          <span id="preview-cta2" class="inline-block px-4 py-1.5 border border-accent/40 text-accent text-xs rounded-lg"></span>
        </div>
      </div>
    </div>

    <!-- Header Links -->
    <section class="bg-gray-900 rounded-lg p-5 border border-gray-700">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wider">Header Links</h2>
        <button type="button" id="add-header-link" class="text-xs text-blue-400 hover:text-blue-300 transition-colors">+ Add Link</button>
      </div>
      <p class="text-[11px] text-gray-600 mb-3">Up to 6 navigation links. Default: Gallery, Blog.</p>
      <div id="header-links" class="space-y-2"></div>
    </section>

    <!-- Footer Links -->
    <section class="bg-gray-900 rounded-lg p-5 border border-gray-700">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wider">Footer Links</h2>
        <button type="button" id="add-footer-link" class="text-xs text-blue-400 hover:text-blue-300 transition-colors">+ Add Link</button>
      </div>
      <p class="text-[11px] text-gray-600 mb-3">Up to 8 footer links. Default: About, GitHub.</p>
      <div id="footer-links" class="space-y-2"></div>
    </section>

    <!-- SEO & Meta Descriptions -->
    <section class="bg-gray-900 rounded-lg p-5 border border-gray-700">
      <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-2">SEO & Meta Descriptions</h2>
      <p class="text-[11px] text-gray-600 mb-4">Shown in search results, social shares, and link previews. Leave blank for defaults.</p>
      <div class="space-y-3">
        <div>
          <label for="meta-home" class="block text-xs text-gray-500 mb-1">Home</label>
          <input type="text" id="meta-home" value={metaHome} placeholder="The artworks I like, with the prompts ready to remix. AI art is art. Hope you like it." maxlength="160"
            class="w-full bg-gray-900 border border-gray-700 rounded-lg px-3 py-1.5 text-white text-sm focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500" />
        </div>
        <div>
          <label for="meta-gallery" class="block text-xs text-gray-500 mb-1">Gallery</label>
          <input type="text" id="meta-gallery" value={metaGallery} placeholder="The ones I love most — feel free to borrow a prompt." maxlength="160"
            class="w-full bg-gray-900 border border-gray-700 rounded-lg px-3 py-1.5 text-white text-sm focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500" />
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <div>
            <label for="meta-tags" class="block text-xs text-gray-500 mb-1">Tags</label>
            <input type="text" id="meta-tags" value={metaTags} placeholder="Browse by mood, style, and vibe." maxlength="160"
              class="w-full bg-gray-900 border border-gray-700 rounded-lg px-3 py-1.5 text-white text-sm focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500" />
          </div>
          <div>
            <label for="meta-models" class="block text-xs text-gray-500 mb-1">Models</label>
            <input type="text" id="meta-models" value={metaModels} placeholder="The AI friends helping me create." maxlength="160"
              class="w-full bg-gray-900 border border-gray-700 rounded-lg px-3 py-1.5 text-white text-sm focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500" />
          </div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <div>
            <label for="meta-blog" class="block text-xs text-gray-500 mb-1">Blog</label>
            <input type="text" id="meta-blog" value={metaBlog} placeholder="Notes on tools, process, and making things I love." maxlength="160"
              class="w-full bg-gray-900 border border-gray-700 rounded-lg px-3 py-1.5 text-white text-sm focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500" />
          </div>
          <div>
            <label for="meta-blog-topics" class="block text-xs text-gray-500 mb-1">Blog Topics</label>
            <input type="text" id="meta-blog-topics" value={metaBlogTopics} placeholder="Browse posts by topic — pick what interests you." maxlength="160"
              class="w-full bg-gray-900 border border-gray-700 rounded-lg px-3 py-1.5 text-white text-sm focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500" />
          </div>
        </div>
        <p class="text-[11px] text-gray-600">Entry and blog post pages auto-generate from content. Max 160 characters each.</p>
      </div>
    </section>

    <!-- Save -->
    <div class="flex gap-3">
      <button type="button" id="save-btn"
        class="bg-blue-600 hover:bg-blue-500 text-white font-medium py-2.5 px-8 rounded-lg transition-colors text-sm">
        Save Config
      </button>
      <a href="/admin" class="text-gray-400 hover:text-white py-2.5 px-4 transition-colors text-sm">Back</a>
    </div>
  </div>

  <!-- Data islands -->
  <script id="header-links-data" type="application/json" set:html={JSON.stringify(headerLinks)} />
  <script id="footer-links-data" type="application/json" set:html={JSON.stringify(footerLinks)} />

  <script>
    // --- Hero live preview ---
    const previewTitle = document.getElementById('preview-title')!;
    const previewSubtitle = document.getElementById('preview-subtitle')!;
    const previewCta1 = document.getElementById('preview-cta1')!;
    const previewCta2 = document.getElementById('preview-cta2')!;

    function updatePreview() {
      previewTitle.innerHTML = (document.getElementById('hero-title') as HTMLInputElement).value || 'Your Title';
      previewSubtitle.textContent = (document.getElementById('hero-subtitle') as HTMLInputElement).value || 'Your subtitle here';
      previewCta1.textContent = (document.getElementById('cta1-text') as HTMLInputElement).value || 'Browse Gallery';
      previewCta2.textContent = (document.getElementById('cta2-text') as HTMLInputElement).value || 'Read the Blog';
    }

    ['hero-title', 'hero-subtitle', 'cta1-text', 'cta2-text'].forEach((id) => {
      document.getElementById(id)?.addEventListener('input', updatePreview);
    });
    updatePreview();

    const msgEl = document.getElementById('message')!;
    function showMsg(text: string, isError: boolean) {
      msgEl.textContent = text;
      msgEl.className = `mb-4 px-4 py-2 rounded-lg text-sm ${isError ? 'bg-red-900/50 text-red-300' : 'bg-green-900/50 text-green-300'}`;
    }

    // --- Link row builder ---
    function makeLinkRow(container: HTMLElement, text: string, url: string, max: number) {
      if (container.children.length >= max) return;
      const row = document.createElement('div');
      row.className = 'flex gap-2 items-center';
      row.innerHTML = `
        <input type="text" placeholder="Label" value="${escHtml(text)}" class="flex-1 bg-gray-900 border border-gray-700 rounded-lg px-3 py-1.5 text-white text-sm focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 link-text" />
        <input type="text" placeholder="/path or https://..." value="${escHtml(url)}" class="flex-1 bg-gray-900 border border-gray-700 rounded-lg px-3 py-1.5 text-white text-sm focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 link-url" />
        <button type="button" class="text-gray-500 hover:text-red-400 text-sm transition-colors link-remove shrink-0 px-1">✕</button>`;
      row.querySelector('.link-remove')!.addEventListener('click', () => row.remove());
      container.appendChild(row);
    }

    function readLinks(container: HTMLElement): { text: string; url: string }[] {
      return Array.from(container.children).map((row) => ({
        text: (row.querySelector('.link-text') as HTMLInputElement).value.trim(),
        url: (row.querySelector('.link-url') as HTMLInputElement).value.trim(),
      })).filter((l) => l.text && l.url);
    }

    // --- Init header links ---
    const headerContainer = document.getElementById('header-links')!;
    const headerData: { text: string; url: string }[] = JSON.parse(document.getElementById('header-links-data')!.textContent!);
    headerData.forEach((l) => makeLinkRow(headerContainer, l.text, l.url, 6));

    document.getElementById('add-header-link')!.addEventListener('click', () => makeLinkRow(headerContainer, '', '', 6));

    // --- Init footer links ---
    const footerContainer = document.getElementById('footer-links')!;
    const footerData: { text: string; url: string }[] = JSON.parse(document.getElementById('footer-links-data')!.textContent!);
    footerData.forEach((l) => makeLinkRow(footerContainer, l.text, l.url, 8));

    document.getElementById('add-footer-link')!.addEventListener('click', () => makeLinkRow(footerContainer, '', '', 8));

    // --- Save ---
    const saveBtn = document.getElementById('save-btn') as HTMLButtonElement;
    saveBtn.addEventListener('click', async () => {
      saveBtn.disabled = true; saveBtn.textContent = 'Saving...';
      const payload: Record<string, string> = {
        site_hero_title: (document.getElementById('hero-title') as HTMLInputElement).value,
        site_hero_subtitle: (document.getElementById('hero-subtitle') as HTMLInputElement).value,
        site_hero_cta_1: JSON.stringify({
          text: (document.getElementById('cta1-text') as HTMLInputElement).value.trim(),
          url: (document.getElementById('cta1-url') as HTMLInputElement).value.trim(),
        }),
        site_hero_cta_2: JSON.stringify({
          text: (document.getElementById('cta2-text') as HTMLInputElement).value.trim(),
          url: (document.getElementById('cta2-url') as HTMLInputElement).value.trim(),
        }),
        site_header_links: JSON.stringify(readLinks(headerContainer)),
        site_footer_links: JSON.stringify(readLinks(footerContainer)),
        meta_desc_home: (document.getElementById('meta-home') as HTMLInputElement).value.trim(),
        meta_desc_gallery: (document.getElementById('meta-gallery') as HTMLInputElement).value.trim(),
        meta_desc_tags: (document.getElementById('meta-tags') as HTMLInputElement).value.trim(),
        meta_desc_models: (document.getElementById('meta-models') as HTMLInputElement).value.trim(),
        meta_desc_blog: (document.getElementById('meta-blog') as HTMLInputElement).value.trim(),
        meta_desc_blog_topics: (document.getElementById('meta-blog-topics') as HTMLInputElement).value.trim(),
      };
      try {
        const res = await fetch('/api/settings', {
          method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload),
        });
        if (!res.ok) throw new Error((await res.json()).error || 'Save failed');
        showMsg('Config saved.', false);
      } catch (err) { showMsg((err as Error).message, true); }
      finally { saveBtn.disabled = false; saveBtn.textContent = 'Save Config'; }
    });

    function escHtml(s: string): string {
      return s.replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    }
  </script>
</AdminLayout>
