---
import MainLayout from '@/layouts/MainLayout.astro';
---

<MainLayout title="Not Found" description="This page drifted away.">
  <div class="max-w-6xl mx-auto px-4 py-24 text-center">
    <p class="text-6xl font-bold text-accent mb-4">404</p>
    <h1 class="text-2xl font-semibold text-text-primary mb-2">Lost in the whisper...</h1>
    <p class="text-text-secondary mb-8">This page drifted away. Maybe it never existed, or maybe it's just shy.</p>
    <a
      href="/"
      class="inline-block px-6 py-2 bg-accent text-white rounded-lg hover:opacity-90 transition-opacity"
    >
      Back to Gallery
    </a>
  </div>
</MainLayout>
