---
import MainLayout from '@/layouts/MainLayout.astro';
import { TaxonomyService, SettingsService } from '@/lib/data';

const { env } = Astro.locals.runtime;
const taxonomy = new TaxonomyService(env.DB);
const settings = new SettingsService(env.DB);
const [tags, metaDesc] = await Promise.all([
  taxonomy.getTagsWithCount(),
  settings.getMetaDesc('tags', 'Browse by mood, style, and vibe.'),
]);
---

<MainLayout title="Tags" description={metaDesc}>
  <section class="max-w-4xl mx-auto px-4 pt-8 sm:pt-12 pb-16">
    <h1 class="text-2xl sm:text-3xl font-extrabold tracking-tight mb-8">Tags</h1>
    {tags.length === 0 ? (
      <p class="text-text-muted">No tags yet. Create some from the admin panel.</p>
    ) : (
      <div class="flex flex-wrap gap-3">
        {tags.map((t) => (
          <a
            href={`/tags/${t.slug}`}
            class="inline-flex items-center gap-2 bg-surface-raised hover:bg-surface-overlay
                   border border-border rounded-lg px-4 py-2 transition-colors"
          >
            <span class="text-text-primary">#{t.title}</span>
            <span class="text-sm text-text-muted">{t.entry_count}</span>
          </a>
        ))}
      </div>
    )}
  </section>
</MainLayout>
