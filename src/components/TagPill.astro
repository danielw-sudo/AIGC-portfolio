---
interface Props {
  href: string;
  label: string;
  count?: number;
  active?: boolean;
}

const { href, label, count, active = false } = Astro.props;
---

<a
  href={href}
  class:list={[
    'inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-sm shrink-0 transition-colors',
    active
      ? 'bg-accent text-white'
      : 'bg-surface-raised text-text-secondary hover:bg-surface-overlay hover:text-text-primary',
  ]}
>
  <span>{label}</span>
  {count !== undefined && (
    <span class:list={['text-xs', active ? 'text-white/70' : 'text-text-muted']}>
      {count}
    </span>
  )}
</a>
