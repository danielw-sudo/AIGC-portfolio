---
import type { BlogPost } from '@/lib/core/types';

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;
const date = post.created_at?.split(' ')[0] ?? '';
const R2 = import.meta.env.R2_PUBLIC_URL || '';
const coverUrl = post.image_url || (post.image_key ? `${R2}/${post.image_key}` : null);
---

<a href={`/blog/${post.slug}`} class="group block rounded-xl overflow-hidden bg-surface-raised border border-border hover:border-accent/40 transition-colors">
  {coverUrl ? (
    <div class="aspect-[16/9] overflow-hidden">
      <img
        src={coverUrl}
        alt={post.title}
        class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-300"
        loading="lazy"
      />
    </div>
  ) : (
    <div class="aspect-[16/9] bg-gradient-to-br from-accent/20 to-accent/5 flex items-center justify-center">
      <span class="text-4xl font-bold text-accent/30">{post.title.charAt(0)}</span>
    </div>
  )}

  <div class="px-4 py-3">
    <h3 class="text-base font-semibold text-text-primary group-hover:text-accent transition-colors line-clamp-2 mb-1">
      {post.title}
    </h3>
    {post.summary && (
      <p class="text-sm text-text-muted line-clamp-2 mb-2">{post.summary}</p>
    )}
    <div class="flex items-center gap-3 text-xs text-text-muted">
      <time>{date}</time>
      {post.topics && post.topics.length > 0 && (
        <div class="flex gap-1.5 overflow-hidden">
          {post.topics.slice(0, 3).map((t) => (
            <span class="bg-accent/10 text-accent rounded px-1.5 py-0.5 truncate max-w-[8rem]">{t.title}</span>
          ))}
        </div>
      )}
    </div>
  </div>
</a>
