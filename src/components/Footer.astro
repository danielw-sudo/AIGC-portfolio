---
import { env } from "cloudflare:workers";
import { SettingsService } from '@/lib/data';

const year = new Date().getFullYear();
const settings = new SettingsService(env.DB);
const siteConfig = await settings.getSiteConfig();

const defaultLinks = [
  { text: 'About', url: '/about' },
  { text: 'GitHub', url: 'https://github.com/danielw-sudo/AIGC-portfolio' },
];
const links = siteConfig.footerLinks.length > 0 ? siteConfig.footerLinks : defaultLinks;
---

<footer class="border-t border-border mt-auto">
  <div class="max-w-6xl mx-auto px-4 py-6 flex flex-col sm:flex-row items-center justify-between gap-2 text-xs text-text-muted">
    <p>&copy; {year} AIGC Portfolio</p>
    <div class="flex items-center gap-4">
      {links.map((link) => {
        const isExternal = link.url.startsWith('http');
        return (
          <a
            href={link.url}
            class="hover:text-text-secondary transition-colors"
            {...(isExternal ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
          >
            {link.text}
          </a>
        );
      })}
    </div>
  </div>
</footer>
